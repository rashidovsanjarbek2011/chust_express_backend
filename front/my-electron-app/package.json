{
  "name": "app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js --host",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "android:sync": "npm run build && npx cap sync"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.22",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.7",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^3.4.18",
    "vite": "^7.1.7",
    "vite-plugin-vue-devtools": "^8.0.2",
    "wait-on": "^9.0.4"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.delivery.app",
    "productName": "DeliveryApp",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}

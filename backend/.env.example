# Database Configuration for Render PostgreSQL
# 
# IMPORTANT: Use the "Internal Connections" pooling URL from Render dashboard
# This uses pgBouncer to manage connections more efficiently
#
# Standard URL format (may hit connection limits):
# DATABASE_URL="postgresql://username:password@host:5432/database?schema=public"
#
# Render Pool Mode URL format (RECOMMENDED for Render):
# DATABASE_URL="postgresql://username:password@host:5433/database?schema=public"
# NOTE: Port 5433 is the pool mode port on Render
#
# Copy this file to .env and fill in with your actual Render database credentials

DATABASE_URL="postgresql://admin_chust_express:PASSWORD@dpg-d6ipjgpaae7s73cllpig-a.frankfurt-postgres.render.com:5433/chust_express_web?schema=public"

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration - Generate a secure secret key
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Migration Security - Generate a secure secret
MIGRATE_SECRET="your-migration-secret-key-change-this"

# Manager Code - Change this to your desired manager code
MANAGER_CODE="MANAGER-SECRET-2026"

# SSL Configuration for PostgreSQL
SSL_MODE="require"
